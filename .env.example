# Server boot
HOST=127.0.0.1
PORT=3000
EXIDUS_RUNTIME_ENV=development

# Runtime paths
# Relative overrides resolve from the repo root.
# Defaults assume `exidus-app` and `obsidian-exidus` are sibling folders.
EXIDUS_DOCS_ROOT=../obsidian-exidus
# EXIDUS_MANIFEST_PATH=../obsidian-exidus/Agentic/Exidus Agent Manifest v1.json
# EXIDUS_DATA_ROOT=.data
# EXIDUS_PUBLIC_DIR=app/public
